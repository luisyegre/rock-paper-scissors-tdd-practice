<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Rock Paper Scissors</title>
  <link rel="stylesheet" href="/public/css/style.css">
</head>
<body>
  <rps-app>
    <rps-chat-sidebar slot="sidebar" id="global-chat"></rps-chat-sidebar>
    <rps-lobby-page slot="main"></rps-lobby-page>

    <span slot="header-info" id="header-info" class="hidden">
      <span class="label">PLAYER:</span>
      <span class="value" id="header-username"></span>
    </span>

    <button slot="header-actions" id="logout-btn" class="hidden">LOGOUT</button>
  </rps-app>

  <script src="/socket.io/socket.io.js"></script>
  <script src="/public/js/session.js"></script>
  <script src="/public/js/matchStorage.js"></script>
  <script src="/public/js/components/rps-app.js"></script>
  <script src="/public/js/components/rps-chat-sidebar.js"></script>
  <script src="/public/js/components/rps-lobby-page.js"></script>
</body>
</html>
