<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Game Room</title>
  <link rel="stylesheet" href="/public/css/style.css">
</head>
<body>
  <rps-app>
    <rps-chat-sidebar slot="sidebar" id="match-chat" class="hidden"></rps-chat-sidebar>
    <rps-game-page slot="main"></rps-game-page>

    <span slot="header-info" id="header-info" style="display:flex; align-items:center; flex-wrap:nowrap; gap:0.4rem; overflow:hidden; max-width:100%;">
      <span class="label" style="flex-shrink:0;">ROUND:</span>
      <span class="value"><span id="current-round">0</span>/3</span>
    </span>

    <button slot="header-actions" id="leave-match-btn-top" class="btn-red">LEAVE</button>
  </rps-app>

  <script src="/socket.io/socket.io.js"></script>
  <script src="/public/js/session.js"></script>
  <script src="/public/js/matchStorage.js"></script>
  <script src="/public/js/components/rps-app.js"></script>
  <script src="/public/js/components/rps-chat-sidebar.js"></script>
  <script src="/public/js/components/rps-game-page.js"></script>
</body>
</html>
